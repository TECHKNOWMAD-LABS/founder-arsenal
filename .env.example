# Environment variable template for Founder Arsenal
# Copy to .env and fill in values — NEVER commit .env to version control

# Optional: API key for external integrations (if adding LLM features)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Database URL for persistence layer
# DATABASE_URL=postgresql://user:password@localhost:5432/founder_arsenal

# Optional: Logging level
# LOG_LEVEL=INFO
